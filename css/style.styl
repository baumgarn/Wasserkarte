// TOOLTIP

.tooltip
	display none
// .tooltip.opaque
// 	--infobg var(--infobgopaque)
.showtooltips .tooltip
	display block
.hastooltip .tooltip
	width: max-content;     
	max-width: 250px;
	white-space: normal;
	overflow-wrap: break-word;
	position: absolute;
	top: calc(100% + 8px);
	left: 5px
	text-align left
	color: white;
	background: var(--infobg);
	font-size 9pt
	padding: 4px 6px
	border-radius: 3px;
	pointer-events: none;
	z-index: 100;
	opacity: 0;
	visibility: hidden;
	user-select none
	transition: opacity .2s ease-in, visibility 0s linear .2s;
	filter: drop-shadow(0 1px 2px rgba(0,0,0,.1));

.hastooltip .tooltip:after
	content: '';
	position: absolute;
	top: -7px;
	left: 12px;
	border-style: solid;
	border-width: 0 4px 7px 4px;
	border-color: transparent transparent var(--infobg) transparent;

.hastooltip .tooltip.left
	max-width: 208px
	top: 50%;
	transform translateY(-50%)
	left: auto;
	right: calc(100% + 10px)

.is-mobile .hastooltip .tooltip.left
	max-width 160px;
	right: calc(100% + 8px)

.hastooltip .tooltip.left:after
	top auto
	left auto
	right -8px
	top calc(50% - 5px);
	border-width: 5px 0 5px 8px;
	border-color: transparent transparent transparent var(--infobg) ;


.hastooltip:hover .tooltip
	opacity: 1;
	visibility: visible;
	transition-delay: .25s;

.menubaritem.was-clicked:hover .tooltip
	opacity 0

.menubar.anyactive:not(.soloactive)
.menubar.anyactive
	.tooltip
		display none

