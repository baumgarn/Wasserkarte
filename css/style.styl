// LOADING 
.loading:after
	position absolute
	content ''
	top calc(45% - 1.25em)
	left calc(50% - 1.25em)
	width 2.5em
	height 2.5em
	background transparent
	border 4px solid #00000022
	border-top 4px solid transparent
	border-bottom 4px solid transparent
	z-index 20000
	border-radius 50%
	animation rotate-spinner 1.5s linear infinite
	pointer-events none

@keyframes rotate-spinner
	from
		transform rotate(0deg)
	to
		transform rotate(360deg)

#ui
#app
	visibility hidden
body.loaded
	#ui
	#app
		visibility visible

